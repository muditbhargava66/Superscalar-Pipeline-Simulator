# Include the README and license
include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md

# Include configuration files
include config.yaml
include pyproject.toml
include .pre-commit-config.yaml

# Include requirements files
include requirements.txt
include requirements-dev.txt

# Include documentation
recursive-include docs *.md *.rst *.txt *.py
recursive-include docs *.png *.jpg *.svg

# Include benchmarks
recursive-include benchmarks *.asm *.txt

# Include examples
recursive-include examples *.py *.yaml *.asm *.md

# Include tests
recursive-include tests *.py

# Exclude development and temporary files
exclude fix_typing_imports.py
exclude pipeline_fixes.py
exclude run_validation.py
exclude test_benchmarks.py
exclude test_runner.py

# Exclude report files (development artifacts)
exclude simulation_results.txt
exclude benchmark_validation_results.json

# Exclude cache and build directories
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.so
global-exclude .coverage
global-exclude htmlcov
global-exclude .pytest_cache
global-exclude .ruff_cache
global-exclude .mypy_cache
global-exclude coverage.xml
global-exclude coverage.html